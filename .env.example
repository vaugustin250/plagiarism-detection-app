# AWS Configuration
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# RDS PostgreSQL Database
RDS_HOST=plagiarism-db.cpmigym2oym2.us-east-2.rds.amazonaws.com
RDS_PORT=5432
RDS_USER=postgres
RDS_PASSWORD=YOUR_RDS_PASSWORD
RDS_DB=plagiarism_db

# S3 Bucket
S3_BUCKET_NAME=plagiarism-detection-docs-augustin

# Pinecone Vector Database
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX_NAME=plagiarism-vectors
PINECONE_ENVIRONMENT=us-west1-gcp

# HuggingFace
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Lambda Configuration
LAMBDA_FUNCTION_NAME=plagiarism-detection
LAMBDA_ROLE_ARN=arn:aws:iam::093954665664:role/plagiarism-lambda-role

# Streamlit Configuration
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# API Configuration
API_GATEWAY_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
CORS_ORIGINS=*

# Model Confidence Thresholds
PLAGIARISM_THRESHOLD=0.7
AI_DETECTION_THRESHOLD=0.6
